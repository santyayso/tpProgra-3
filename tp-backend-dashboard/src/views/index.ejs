<%- include("partials/head.ejs")%>
    <%- include("partials/nav.ejs")%>

        <main>

            <section class="seccion-productos">


                <h2>PRODUCTOS ACTIVOS</h2>
                <div class="contenedor-productos" id="contenedor-activos">


                    <% if (productosActivos.length <=0 ) { %>
                        <div class="mensaje-error">
                            <p>
                                <%="No se encontraron productos en esta seccion"%>
                            </p>
                        </div>

                        <% } else { %>

                            <% productosActivos.forEach(producto=> { %>

                                <div class="card-producto">
                                    <img src="<%= producto.imagen %>" alt="<%= producto.nombre %>">

                                    <h4>
                                        <%= producto.nombre %>
                                    </h4>

                                    <p> <strong> ID: <%= producto.id %></strong>
                                    </p>

                                    <p> <strong>$<%= producto.precio %></strong>
                                    </p>

                                    <p><strong>Categoria: <%= producto.categoria %> </strong>
                                    </p>

                                </div>

                                <% }) %>

                                    <% } %>

                </div>
            </section>
            <section class="seccion-productos" >
                <h2>PRODUCTOS INACTIVOS</h2>

                <div class="contenedor-productos" id="contenedor-inactivos">

                    <% if (productosInactivos.length <=0 ) { %>

                        <div class="mensaje-error">
                            <p>
                                <%="No se encontraron productos en esta seccion"%>
                            </p>
                        </div>

                        <% } else { %>

                            <% productosInactivos.forEach(producto=> { %>

                                <div class="card-producto">
                                    <img src="<%= producto.imagen %>" alt="<%= producto.nombre %>">

                                    <h4>
                                        <%= producto.nombre %>
                                    </h4>

                                    <p> <strong> ID: <%= producto.id %></strong>
                                    </p>

                                    <p> <strong>$<%= producto.precio %></strong>
                                    </p>

                                    <p>Categoria: <%= producto.categoria %>
                                    </p>

                                </div>

                                <% }) %>

                                    <% } %>

                </div>

            </section>





        </main>

        <%- include("partials/footer.ejs")%>